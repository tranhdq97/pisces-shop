# Copy to .env and fill in values
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pisces_db
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional — pytest only (default matches docker-compose db: postgres/postgres, DB pisces_test)
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pisces_test
